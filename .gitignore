# Ignore everything by default. Keep this repo focused on the static site.
*

# Keep directories traversable for explicit allow rules.
!*/

# Repository metadata and docs.
!.gitignore
!README.md
!AGENTS.md
!CONTEXT.md
!docs/
!docs/**

# Static website package for Netlify.
!site/
!site/**

# Always ignore common temporary/generated files even inside allowed folders.
**/~$*
**/*.tmp
**/*.bak
**/*.log
**/*.zip
**/.DS_Store
**/Thumbs.db
